<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Login</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background-color: #f7f7f7;
      color: #222;
    }

    .login-container {
      max-width: 420px;
      margin: 60px auto;
      background: white;
      padding: 30px;
      border-radius: 10px;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
      text-align: center;
    }

    h1 {
      color: #0d3b66;
      margin-bottom: 10px;
    }

    .subtitle {
      margin-bottom: 24px;
      color: #555;
    }

    .error {
      color: red;
      font-weight: bold;
      margin-bottom: 12px;
    }

    .success {
      color: green;
      font-weight: bold;
      margin-bottom: 12px;
    }

    .google-login {
      display: block;
      width: 100%;
      padding: 12px;
      background-color: white;
      color: #333;
      border: 1px solid #ccc;
      border-radius: 6px;
      font-weight: bold;
      text-decoration: none;
      box-sizing: border-box;
      margin-bottom: 18px;
    }

    .google-login:hover {
      background-color: #f1f1f1;
    }

    .divider {
      display: flex;
      align-items: center;
      gap: 10px;
      color: #777;
      font-size: 14px;
      margin: 18px 0;
    }

    .divider::before,
    .divider::after {
      content: "";
      flex: 1;
      height: 1px;
      background-color: #ddd;
    }

    form {
      text-align: left;
    }

    label {
      display: block;
      margin-bottom: 6px;
      font-weight: bold;
    }

    input {
      width: 100%;
      padding: 10px;
      margin-bottom: 16px;
      border: 1px solid #ccc;
      border-radius: 6px;
      box-sizing: border-box;
    }

    button {
      width: 100%;
      padding: 12px;
      background-color: #2a9d8f;
      color: white;
      border: none;
      border-radius: 6px;
      font-weight: bold;
      cursor: pointer;
    }

    button:hover {
      background-color: #23867a;
    }
  </style>
</head>
<body>
  <div class="login-container">
    <h1>North Shore Family Vacation Rentals</h1>
    <p class="subtitle">Admin Login</p>

    <% if (error) { %>
      <p class="error"><%= error %></p>
    <% } %>

    <% if (googleError) { %>
      <p class="error"><%= googleError %></p>
    <% } %>

    <% if (logoutMessage) { %>
      <p class="success"><%= logoutMessage %></p>
    <% } %>

    <a class="google-login" href="/auth/google">
      Sign in with Google
    </a>

    <div class="divider">or</div>

    <form action="/admin/login" method="POST">
      <label for="email">Email</label>
      <input 
        type="email" 
        id="email" 
        name="email" 
        placeholder="Enter your admin email" 
        required 
      />

      <label for="password">Password</label>
      <input 
        type="password" 
        id="password" 
        name="password" 
        placeholder="Enter your password" 
        required 
      />

      <button type="submit">Log In</button>
    </form>
  </div>
</body>
</html>